# Ignore Terraform local state files
*.tfstate
*.tfstate.*

# Ignore Terraform cache directories
.terraform/

# Ignore lock files (optional, can be committed if desired)
.terraform.lock.hcl

# Ignore local variable files (may contain secrets)
*.tfvars
*.tfvars.b64
*.b64
# OS files
.DS_Store
Thumbs.db

# Editor / IDE files
.vscode/
.idea/
*.swp

# Logs
*.log

# Terraform
**/terraform/.terraform/
**/terraform/*.tfstate
**/terraform/*.tfstate.*
**/terraform/*.tfvars
**/terraform/*.tfvars.json
**/terraform/crash.log
**/terraform/override.tf
**/terraform/override.tf.json
**/terraform/*_override.tf
**/terraform/*_override.tf.json
**/terraform/.terraformrc
**/terraform/terraform.rc
**/terraform/*.tfplan
**/terraform/tfplan
**/terraform/*.tfplan.binary

# App-specific
node_modules/
app/node_modules/
app/dist/
app/build/
app/__pycache__/
app/*.env

# Helm binaries
helm-v*.zip
windows-amd64/

monitoring-setup/alertmanager-template.yaml

# Scripts backup files
*.bak
*.sh.bak

# Kubernetes backup files
k8s/*.bak

# Temporary files
*.tmp
*.temp