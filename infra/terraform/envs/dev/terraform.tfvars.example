# Development environment — copy to terraform.tfvars. Multi-env: see envs/README.md
#
# =============================================================================
# BOOTSTRAP MODE (default)
# Defer NAT/UDR, Cilium, Azure Policy, monitoring addon, Argo CD, and workload
# pools until the cluster reaches Succeeded. Re-enable in order — see bottom of
# this file and docs/BOOTSTRAP_FIXES.md → "Stable platform re-enable".
# =============================================================================

# Resource Group Configuration
resource_group_name = "ola-rg-dev"
location            = "uksouth"

# --- AKS (bootstrap-minimal) ---
aks_name            = "ola-aks-dev"
kubernetes_version  = "1.34.8" # Standard-tier supported patch — not LTS-only (1.31.x) or latest (1.35+)

default_node_pool_name            = "system"
default_node_pool_vm_size         = "Standard_D2s_v3"
default_node_pool_node_count      = 1
default_node_pool_os_disk_size_gb = 128
enable_auto_scaling               = true
min_node_count                    = 1
max_node_count                    = 3
system_pool_taints                = [] # Re-add CriticalAddonsOnly after workload pool exists

workload_node_pools = {} # Add workload pool in stable phase 1

# --- Networking (bootstrap: loadBalancer egress, azure policy — NO NAT/UDR/Cilium) ---
enable_nat_gateway  = false # true → userDefinedRouting via NAT (defer until stable phase 3)
network_policy      = "azure"
network_dataplane   = "azure"
network_plugin_mode = "overlay"

enable_private_dns = true
enable_nsg         = true

# ACR Configuration
acr_name            = "olaacr01dev"
acr_georeplications = []

# Key Vault Configuration
key_vault_name                   = "ola-kv-dev"
key_vault_sku                    = "standard"
key_vault_purge_protection       = false
key_vault_public_access          = false
key_vault_network_default_action = "Deny"
key_vault_network_bypass         = "None"
key_vault_allowed_ips            = []

enable_acr_private_endpoint      = true
enable_keyvault_private_endpoint = true
acr_public_network_access        = false

# Bastion + ops VM
enable_bastion                = true
jumpbox_vm_name               = "aks-operations-vm"
jumpbox_install_docker        = false
jumpbox_install_terraform     = false
jumpbox_install_nodejs        = false
jumpbox_install_github_runner = false

# Deferred until stable (keep false for bootstrap)
enable_argocd               = false
enable_aks_monitoring_addon = false
enable_azure_policy         = false

enable_log_analytics = true # Workspace only; addon off until stable phase 5

disable_local_accounts = true
enable_azure_rbac      = true
vm_admin_login_principal_ids = ["be2dd317-dac9-4f54-922a-6aab723c19e0"]
admin_group_object_ids       = []
operator_group_object_ids    = []

# Workload Identity
k8s_namespace                          = "default"
workload_identity_service_account_name = "workload-identity-sa"

# GitHub Actions OIDC
enable_github_oidc = true
github_repository  = "OlatunbosunIbiyinka/Olatunbosun-portfolio-project"
github_branch      = "main"
github_oidc_app_name        = "github-actions-oidc"
github_oidc_credential_name = "github-actions-federated-credential"
github_oidc_additional_subjects = [
  "repo:OlatunbosunIbiyinka/Olatunbosun-portfolio-project:ref:refs/heads/develop",
  "repo:OlatunbosunIbiyinka/Olatunbosun-portfolio-project:pull_request",
]
github_oidc_role_assignments      = ["Reader"]
enable_github_oidc_tfstate_access = true
tfstate_resource_group_name       = "tfstate-rg"
tfstate_storage_account_name      = "olaportfolio001"

tags = {
  Environment = "development"
  Project     = "portfolio"
  ManagedBy   = "Terraform"
  Owner       = "DevOps"
}

# =============================================================================
# STABLE PLATFORM — enable ONE phase at a time, then: terraform apply
# (from ops VM). Verify kubectl / nodes healthy before the next phase.
# =============================================================================
#
# Phase 1 — Workload pool + system taints
# system_pool_taints = ["CriticalAddonsOnly=true:NoSchedule"]
# workload_node_pools = {
#   "workload" = {
#     vm_size             = "Standard_D4s_v3"
#     node_count          = 1
#     os_disk_size_gb     = 128
#     os_sku              = "Ubuntu"
#     enable_auto_scaling = true
#     min_count           = 1
#     max_count           = 5
#     max_pods            = 30
#     node_labels = {
#       "pool.type"               = "user"
#       "workload"                = "application"
#       "node.kubernetes.io/role" = "workload"
#     }
#     node_taints = []
#     mode        = "User"
#   }
# }
#
# Phase 2 — Azure Policy
# enable_azure_policy = true
#
# Phase 3 — NAT Gateway + UDR egress (predictable outbound IP)
# enable_nat_gateway = true
#
# Phase 4 — Cilium (may recycle nodes; run during maintenance window)
# network_policy    = "cilium"
# network_dataplane = "cilium"
#
# Phase 5 — Container Insights addon
# enable_aks_monitoring_addon = true
#
# Phase 6 — GitOps (or run: bash scripts/phase2-on-vm.sh)
# enable_argocd = true
